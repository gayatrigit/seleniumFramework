<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="FreeCRM Test Suite">

    <!-- Register Listener -->
    <listeners>
        <listener class-name="com.freecrm.listeners.TestListener"/>
        <!-- Example:
        <listener class-name="com.aventstack.extentreports.testng.listener.ExtentITestListenerClassAdapter"/>
        -->
    </listeners>

    <test name="Smoke Tests">

        <!-- Execute only Smoke group -->
        <groups>
            <run>
                <include name="Smoke"/>
            </run>
        </groups>

        <classes>
            <class name="com.freecrm.testcases.LoginPageTest"/>
            <class name="com.freecrm.testcases.HomePageTest"/>
            <class name="com.freecrm.testcases.ContactsPageTest"/>
        </classes>

    </test>

</suite>